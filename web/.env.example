# ============================================================
# TugasKu × Explore Lab — environment variables
# Copy to .env.local for local dev; configure on host for prod.
# Do NOT expose anything that is NOT prefixed with NEXT_PUBLIC_
# ============================================================

# Public app URL (used for auth redirect_to and OAuth callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (project URL + anon key are safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — SERVER ONLY. Never expose to the browser.
# Used for privileged operations (e.g. token storage, admin actions).
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth (Calendar integration) — server only.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:3000/api/integrations/google-calendar/callback

# 32-byte hex key used to encrypt provider tokens at rest (AES-256-GCM).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=
